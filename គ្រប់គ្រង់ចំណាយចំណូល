  const amtKhr=debtCur==='khr'?Math.round(raw):Math.round(raw*rate);
  await push(debtRef,{name,amtUsd,amtKhr,origCur:debtCur,paid:false,paidAmtUsd:0,paidAmtKhr:0,rateAtTime:rate,payments:{},date:document.getElementById('d-date').value||today(),due:document.getElementById('d-due').value||'',note:document.getElementById('d-note').value.trim(),ts:Date.now()});
