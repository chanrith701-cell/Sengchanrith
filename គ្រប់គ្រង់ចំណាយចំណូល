window.clearUsd=async function(){if(!requireAdmin())return;if(!Object.keys(usdTx).length)return;if(confirm('លុបប្រតិបត្តិការ USD ទាំងអស់?')){await set(usdRef,null);showToast('🗑 បានលុបទាំងអស់!','info');}};
window.setUsdFilter=function(f,el){usdFilter=f;document.querySelectorAll('#tab-usd .filter-btn').forEach(b=>b.classList.remove('active'));el.classList.add('active');renderUsdList();};
window.renderUsdList=renderUsdList;

function renderUsd(){
  const list=objArr(usdTx);
  const inc=list.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0);
  const exp=list.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0);
  const bal=inc-exp;
  document.getElementById('u-income').textContent=fmtD(inc);
  document.getElementById('u-expense').textContent=fmtD(exp);
  const be=document.getElementById('u-balance');be.textContent=fmtD(bal);be.style.color=bal>=0?'var(--income)':'var(--expense)';
  renderUsdList();renderUsdChart();
}
function renderUsdList(){
  const s=document.getElementById('u-search').value.toLowerCase();
  const list=objArr(usdTx).sort((a,b)=>b.ts-a.ts).filter(t=>{
    if(usdFilter!=='all'&&t.type!==usdFilter)return false;
    if(s&&!t.desc.toLowerCase().includes(s)&&!t.category.toLowerCase().includes(s))return false;
    return true;
  });
  const c=document.getElementById('u-list');
  if(!list.length){c.innerHTML=`<div class="empty-state"><div class="emoji">🔍</div><p>រកមិនឃើញ</p></div>`;return;}
  c.innerHTML=list.map((t,i)=>`
    <div class="t-item ${t.type}" style="animation-delay:${i*0.04}s">
      <div class="t-icon ${t.type}">${t.type==='income'?'📈':'📉'}</div>
      <div class="t-info"><div class="t-desc">${t.desc}</div><div class="t-meta"><span class="t-cat">${t.category}</span><span>${fmtDate(t.date)}</span></div></div>
      <div class="t-amt ${t.type}">${t.type==='income'?'+':'-'}${fmtD(t.amount)}</div>
      <button class="t-del" onclick="delUsd('${t._id}')">✕</button>
    </div>`).join('');
}
function renderUsdChart(){
  const c=document.getElementById('u-chart');const days=last7();const list=objArr(usdTx);
  const data=days.map(date=>({date,income:list.filter(t=>t.type==='income'&&t.date===date).reduce((s,t)=>s+t.amount,0),expense:list.filter(t=>t.type==='expense'&&t.date===date).reduce((s,t)=>s+t.amount,0)}));
  const mx=Math.max(...data.map(d=>Math.max(d.income,d.expense)),1);
  const dn=['អាទិ','ច.','អ.','ព.','ព្ហ.','សុ.','សៅ'];
  c.innerHTML=data.map(d=>{const dow=new Date(d.date+'T00:00:00').getDay();const ih=Math.max((d.income/mx)*100,d.income>0?4:0);const eh=Math.max((d.expense/mx)*100,d.expense>0?4:0);return`<div class="bar-group"><div style="display:flex;gap:3px;align-items:flex-end;width:100%;height:100%;"><div class="bar income" style="height:${ih}%;flex:1"></div><div class="bar expense" style="height:${eh}%;flex:1"></div></div><div class="bar-label">${dn[dow]}</div></div>`;}).join('');
}

