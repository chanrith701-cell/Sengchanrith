window.togglePaid=async function(id){
  if(!requireAdmin())return;
  const d=debts[id];if(!d)return;
  const nowPaid=!d.paid;
  const updates={paid:nowPaid};
  if(nowPaid){
    updates.paidAmtUsd=d.amtUsd;updates.paidAmtKhr=d.amtKhr;
    const alreadyPaid=objArr(d.payments||{}).reduce((s,p)=>s+p.amtUsd,0);
    const rem=d.amtUsd-alreadyPaid;
    if(rem>0.001){updates[`payments/p${Date.now()}`]={who:'ទូទាត់ពេញ',amtUsd:rem,amtKhr:Math.round(rem*(d.rateAtTime||rate)),date:today()};}
  }else{updates.paidAmtUsd=0;updates.paidAmtKhr=0;updates.payments={};}
  await update(ref(db,'debts/'+id),updates);
  showToast(nowPaid?'✅ បានទូទាត់!':'↩️ មិនទាន់ទូទាត់','info');
};
window.openPartial=function(id){
  if(!isAdmin){showToast('🔒 សូម Login មុន!','error');document.getElementById('auth-modal').style.display='flex';return;}
  const area=document.getElementById('pa-'+id);
  area.classList.toggle('open');
  if(area.classList.contains('open')){const pd=document.getElementById('pd-'+id);if(pd&&!pd.value)pd.valueAsDate=new Date();}
};
window.confirmPartial=async function(id){
  if(!requireAdmin())return;
  const d=debts[id];if(!d)return;
  const v=parseFloat(document.getElementById('pi-'+id).value);
  const who=(document.getElementById('pn-'+id).value||'').trim()||'—';
  const payDate=document.getElementById('pd-'+id).value||today();
  if(!v||v<=0){showToast('សូមបញ្ចូលចំនួន!','error');return;}
  let payUsd,payKhr;
  if(d.origCur==='usd'){payUsd=v;payKhr=Math.round(v*(d.rateAtTime||rate));}
  else{payKhr=Math.round(v);payUsd=v/(d.rateAtTime||rate);}
  if(payUsd>d.amtUsd-d.paidAmtUsd+0.001){showToast('លើសចំនួននៅជំពាក់!','error');return;}
  const newPaidUsd=d.paidAmtUsd+payUsd;
  const newPaidKhr=d.paidAmtKhr+payKhr;
  const nowPaid=newPaidUsd>=d.amtUsd-0.001;
  await update(ref(db,'debts/'+id),{paidAmtUsd:newPaidUsd,paidAmtKhr:newPaidKhr,paid:nowPaid,[`payments/p${Date.now()}`]:{who,amtUsd:payUsd,amtKhr:payKhr,date:payDate}});
  showToast(`✅ ${who} បានសង ${d.origCur==='usd'?fmtD(payUsd):fmtK(payKhr)+'៛'}!`,'success');
};
window.delDebt=async function(id){if(!requireAdmin())return;await remove(ref(db,'debts/'+id));showToast('🗑 បានលុប!','info');};
window.clearDebt=async function(){if(!requireAdmin())return;if(!Object.keys(debts).length)return;if(confirm('លុបការជំពាក់ទាំងអស់?')){await set(debtRef,null);showToast('🗑 បានលុបទាំងអស់!','info');}};
window.setDebtFilter=function(f,el){debtFilter=f;document.querySelectorAll('#tab-debt .filter-btn').forEach(b=>b.classList.remove('active'));el.classList.add('active');renderDebtList();};
window.renderDebtList=renderDebtList;

function renderDebt(){
  const usdD=objArr(debts).filter(d=>d.origCur==='usd');
  const khrD=objArr(debts).filter(d=>d.origCur==='khr');
  const tU=usdD.reduce((s,d)=>s+d.amtUsd,0),rU=usdD.reduce((s,d)=>s+d.paidAmtUsd,0);
  const tK=khrD.reduce((s,d)=>s+d.amtKhr,0),rK=khrD.reduce((s,d)=>s+d.paidAmtKhr,0);
  document.getElementById('d-total-usd').textContent=fmtD(tU);
  document.getElementById('d-recv-usd').textContent=fmtD(rU);
  document.getElementById('d-remain-usd').textContent=fmtD(tU-rU);
  document.getElementById('d-total-khr').textContent=tK>0?fmtK(tK)+'៛':'';
  document.getElementById('d-recv-khr').textContent=rK>0?fmtK(rK)+'៛':'';
  document.getElementById('d-remain-khr').textContent=tK-rK>0?fmtK(tK-rK)+'៛':'';
  renderDebtList();
}
function renderDebtList(){
  const s=document.getElementById('d-search').value.toLowerCase();
  const list=objArr(debts).sort((a,b)=>b.ts-a.ts).filter(d=>{
    if(debtFilter==='unpaid'&&d.paid)return false;
    if(debtFilter==='paid'&&!d.paid)return false;
    if(s&&!d.name.toLowerCase().includes(s)&&!(d.note||'').toLowerCase().includes(s))return false;
    return true;
  });
  const c=document.getElementById('d-list');
  if(!list.length){c.innerHTML=`<div class="empty-state"><div class="emoji">🤝</div><p>រកមិនឃើញការជំពាក់</p></div>`;return;}
  c.innerHTML=list.map((d,i)=>{
    const pct=d.amtUsd>0?Math.round((d.paidAmtUsd/d.amtUsd)*100):0;
    const remUsd=d.amtUsd-d.paidAmtUsd, remKhr=d.amtKhr-d.paidAmtKhr;
    const overdue=isOverdue(d.due,d.paid);
    const mainAmt=d.origCur==='usd'?fmtD(d.amtUsd):fmtK(d.amtKhr)+'៛';
    const subAmt=d.origCur==='usd'?'≈'+fmtK(d.amtKhr)+'៛':'≈'+fmtD(d.amtUsd);
    const paidMain=d.origCur==='usd'?fmtD(d.paidAmtUsd):fmtK(d.paidAmtKhr)+'៛';
    const remMain=d.origCur==='usd'?fmtD(remUsd):fmtK(remKhr)+'៛';
    const piPh=d.origCur==='usd'?'0.00':'0', piSt=d.origCur==='usd'?'0.01':'100', piMx=d.origCur==='usd'?remUsd:remKhr;
    const payments=objArr(d.payments||{}).sort((a,b)=>a.date>b.date?1:-1);
    return`<div class="d-item ${d.paid?'paid':''}" style="animation-delay:${i*0.04}s">
      <div class="d-main">
        <div class="d-icon ${d.paid?'paid':''}">${d.paid?'✅':'🤝'}</div>
        <div class="d-info">
          <div class="d-name">${d.name}${overdue?' <span style="color:#dc2626;font-size:0.72rem">⚠️ ហួស</span>':''}</div>
          <div class="d-meta">
            <span class="d-badge ${d.paid?'paid':'unpaid'}">${d.paid?'✅ ទូទាត់':'⏳ ជំពាក់'}</span>
            <span class="d-cur-badge">${d.origCur==='usd'?'💵 USD':'🇰🇭 KHR'}</span>
            <span>ខ្ចី: ${fmtDate(d.date)}</span>
            ${d.due?`<span style="color:${overdue?'#dc2626':'var(--text3)'}">ថ្ងៃ: ${fmtDate(d.due)}</span>`:''}
            ${d.note?`<span>📝 ${d.note}</span>`:''}
          </div>
        </div>
        <div class="d-right">
          <div class="d-amt ${d.paid?'paid':''}">${mainAmt}<div class="d-amt-sub">${subAmt}</div></div>
          <div class="d-actions">
            ${!d.paid?`
              <button class="d-pay-btn" onclick="openPartial('${d._id}')">💵 បន្តិច</button>
              <button class="d-pay-btn" onclick="togglePaid('${d._id}')">✅ ទូទាត់</button>
            `:`<button class="d-pay-btn un" onclick="togglePaid('${d._id}')">↩️ មិនទាន់</button>`}
            <button class="d-del-btn" onclick="delDebt('${d._id}')">✕</button>
          </div>
        </div>
      </div>
      <div class="d-progress-wrap">
        <div class="d-progress-label"><span>បានទទួល: ${paidMain}</span><span>នៅខ្វះ: ${remMain} (${pct}%)</span></div>
        <div class="d-progress-bar"><div class="d-progress-fill" style="width:${pct}%"></div></div>
      </div>
      <div class="partial-area" id="pa-${d._id}">
        <input type="text" id="pn-${d._id}" placeholder="ឈ្មោះអ្នកសង..." style="flex:1.2"/>
        <input type="number" id="pi-${d._id}" placeholder="${piPh}" min="0.01" step="${piSt}" max="${piMx}" style="flex:1"/>
        <input type="date" id="pd-${d._id}" style="flex:1"/>
        <button class="partial-confirm" onclick="confirmPartial('${d._id}')">✅ បញ្ជាក់</button>
      </div>
      ${payments.length?`<div class="pay-history">
        <div class="pay-history-title">📜 ប្រវត្តិទូទាត់</div>
        ${payments.map(p=>`<div class="pay-history-row"><span class="pay-who">👤 ${p.who||'—'}</span><span class="pay-amt">${d.origCur==='usd'?fmtD(p.amtUsd):fmtK(p.amtKhr)+'៛'}</span><span class="pay-date">📅 ${fmtDate(p.date)}</span></div>`).join('')}
      </div>`:''}
    </div>`;
  }).join('');
}
</script>

</body>
</html>
