window.addDebt=async function(){
  if(!requireAdmin())return;
  const name=document.getElementById('d-name').value.trim();
  const raw=parseFloat(document.getElementById('d-amount').value);
  if(!name){showToast('សូមបញ្ចូលឈ្មោះ!','error');return;}
  if(!raw||raw<=0){showToast('សូមបញ្ចូលចំនួន!','error');return;}
