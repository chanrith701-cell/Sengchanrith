// ─── Auth ──────────────────────────────────────────────────────
window.doLogin=async function(){
  const email=document.getElementById('login-email').value.trim();
  const pass=document.getElementById('login-pass').value;
  const errEl=document.getElementById('auth-error');
  const btn=document.getElementById('login-btn');
  if(!email||!pass){errEl.textContent='សូមបញ្ចូល Email និង Password!';errEl.classList.add('show');return;}
  btn.disabled=true;btn.textContent='⏳ កំពុង Login...';
  errEl.classList.remove('show');
  try{
    await signInWithEmailAndPassword(auth,email,pass);
    document.getElementById('auth-modal').style.display='none';
    document.getElementById('login-email').value='';
    document.getElementById('login-pass').value='';
  }catch(e){
    const msgs={'auth/wrong-password':'ពាក្យសម្ងាត់មិនត្រឹមត្រូវ!','auth/user-not-found':'រកមិនឃើញ Account!','auth/invalid-email':'Email មិនត្រឹមត្រូវ!','auth/invalid-credential':'Email ឬ Password មិនត្រឹមត្រូវ!'};
    errEl.textContent=msgs[e.code]||'Login មិនបានសម្រេច!';
    errEl.classList.add('show');
  }
  btn.disabled=false;btn.textContent='🔑 Login';
};

window.doLogout=async function(){
  if(confirm('ចង់ Logout ពិតមែនទេ?')){await signOut(auth);}
};

window.closeLoginModal=function(){
  document.getElementById('auth-modal').style.display='none';
};

// Auth state change → show/hide admin UI
onAuthStateChanged(auth,user=>{
  isAdmin=!!user;
  document.body.classList.toggle('is-admin',isAdmin);
  const adminBar=document.getElementById('admin-bar');
  const guestBar=document.getElementById('guest-bar');
  if(isAdmin){
    adminBar.classList.remove('hidden');
    guestBar.style.display='none';
    document.getElementById('admin-email-show').textContent=user.email;
    document.getElementById('auth-modal').style.display='none';
  }else{
    adminBar.classList.add('hidden');
    guestBar.style.display='flex';
  }
  renderUsd();renderKhr();renderDebt();
});

