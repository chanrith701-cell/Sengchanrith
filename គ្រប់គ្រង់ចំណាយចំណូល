<!DOCTYPE html>

<html lang="km">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>គ្រប់គ្រងចំណាយចំណូល</title>
<link href="https://fonts.googleapis.com/css2?family=Hanuman:wght@400;700;900&family=Kantumruy+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#f0f4ff; --surface:#fff; --surface2:#f5f7ff; --surface3:#e8ecf8;
  --income:#16a34a; --expense:#dc2626; --accent:#7c6af7; --accent2:#a78bfa;
  --debt:#d97706; --debt-bg:#fef3c7; --debt-border:#fde68a;
  --khr:#b45309; --khr-bg:#fffbeb; --khr-border:#fde68a;
  --text:#1e1b4b; --text2:#6366a0; --text3:#9499c8;
  --border:#dde1f5; --income-bg:#dcfce7; --expense-bg:#fee2e2;
  --shadow:0 4px 24px rgba(124,106,247,0.08);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Kantumruy Pro',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 70% 50% at 0% 0%,rgba(167,139,250,0.18) 0%,transparent 55%),radial-gradient(ellipse 60% 50% at 100% 100%,rgba(99,179,237,0.15) 0%,transparent 55%);pointer-events:none;z-index:0;}
.container{max-width:900px;margin:0 auto;padding:24px 16px;position:relative;z-index:1;}

/* Loading overlay */
#loading-overlay{position:fixed;inset:0;background:rgba(240,244,255,0.95);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;gap:14px;}
#loading-overlay .spin{width:44px;height:44px;border:4px solid var(–border);border-top-color:var(–accent);border-radius:50%;animation:spin 0.8s linear infinite;}
#loading-overlay p{color:var(–text2);font-size:0.9rem;font-weight:500;}
@keyframes spin{to{transform:rotate(360deg);}}

/* Connection status */
.conn-bar{display:flex;align-items:center;gap:7px;padding:7px 14px;border-radius:99px;font-size:0.75rem;font-weight:600;margin-bottom:16px;width:fit-content;margin-left:auto;}
.conn-bar.online{background:#dcfce7;color:#16a34a;}
.conn-bar.offline{background:#fee2e2;color:#dc2626;}
.conn-dot{width:7px;height:7px;border-radius:50%;background:currentColor;}

header{text-align:center;margin-bottom:18px;animation:fadeDown 0.6s ease both;}
header h1{font-family:‘Hanuman’,serif;font-weight:900;font-size:clamp(1.7rem,5vw,2.6rem);background:linear-gradient(135deg,#7c6af7 0%,#a78bfa 50%,#60a5fa 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1.2;}
header p{color:var(–text2);font-size:0.88rem;margin-top:5px;font-weight:300;}

/* TABS */
.tab-nav{display:flex;gap:5px;margin-bottom:22px;background:var(–surface);border:1px solid var(–border);border-radius:14px;padding:5px;box-shadow:var(–shadow);}
.tab-btn{flex:1;padding:9px 8px;border-radius:10px;border:none;background:transparent;color:var(–text2);font-family:‘Kantumruy Pro’,sans-serif;font-size:0.82rem;font-weight:600;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:4px;white-space:nowrap;}
.tab-btn.active{background:linear-gradient(135deg,#7c6af7,#a78bfa);color:#fff;box-shadow:0 3px 12px rgba(124,106,247,0.3);}
.tab-btn.khr-tab.active{background:linear-gradient(135deg,#b45309,#d97706);box-shadow:0 3px 12px rgba(180,83,9,0.3);}
.tab-btn.debt-tab.active{background:linear-gradient(135deg,#d97706,#f59e0b);box-shadow:0 3px 12px rgba(217,119,6,0.3);}
.tab-panel{display:none;}
.tab-panel.active{display:block;animation:fadeUp 0.3s ease both;}

/* CARDS */
.summary{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:24px;}
.card{background:var(–surface);border:1px solid var(–border);border-radius:16px;padding:18px;position:relative;overflow:hidden;transition:transform 0.2s;box-shadow:var(–shadow);}
.card:hover{transform:translateY(-2px);}
.card::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;}
.card.income::before{background:linear-gradient(90deg,transparent,var(–income),transparent);}
.card.expense::before{background:linear-gradient(90deg,transparent,var(–expense),transparent);}
.card.balance::before{background:linear-gradient(90deg,transparent,var(–accent),transparent);}
.card.debt-c::before{background:linear-gradient(90deg,transparent,var(–debt),transparent);}
.card-label{font-size:0.74rem;color:var(–text2);font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.card-amount{font-family:‘Hanuman’,serif;font-weight:700;font-size:clamp(1rem,2.5vw,1.6rem);line-height:1.1;word-break:break-all;}
.card.income .card-amount{color:var(–income);}
.card.expense .card-amount{color:var(–expense);}
.card.balance .card-amount{color:var(–accent);}
.card.debt-c .card-amount{color:var(–debt);}
.card-sub{font-size:0.72rem;color:var(–khr);font-weight:700;margin-top:3px;}
.card-icon{position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:1.8rem;opacity:0.13;}

/* FORM */
.form-section{background:var(–surface);border:1px solid var(–border);border-radius:20px;padding:22px;margin-bottom:24px;box-shadow:var(–shadow);}
.form-section.khr-form{border-color:var(–khr-border);background:#fffdf5;}
.form-section.debt-form{border-color:var(–debt-border);background:#fffdf5;}
.form-title{font-family:‘Hanuman’,serif;font-size:1.05rem;font-weight:700;color:var(–accent);margin-bottom:18px;display:flex;align-items:center;gap:8px;}
.form-title.khr-t{color:var(–khr);}
.form-title.debt-t{color:var(–debt);}
.type-toggle{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:18px;}
.toggle-btn{padding:11px;border-radius:10px;border:2px solid transparent;background:var(–surface2);color:var(–text2);font-family:‘Kantumruy Pro’,sans-serif;font-size:0.9rem;font-weight:600;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:5px;}
.toggle-btn.income.active{background:var(–income-bg);border-color:var(–income);color:var(–income);}
.toggle-btn.expense.active{background:var(–expense-bg);border-color:var(–expense);color:var(–expense);}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-group.full{grid-column:1/-1;}
label{font-size:0.8rem;color:var(–text2);font-weight:500;}
input,select{background:var(–surface2);border:1.5px solid var(–border);border-radius:10px;color:var(–text);font-family:‘Kantumruy Pro’,sans-serif;font-size:0.9rem;padding:9px 12px;outline:none;transition:border-color 0.2s,box-shadow 0.2s;width:100%;}
input:focus,select:focus{border-color:var(–accent);box-shadow:0 0 0 3px rgba(124,106,247,0.14);background:#fff;}
.khr-form input:focus,.khr-form select:focus{border-color:var(–khr);box-shadow:0 0 0 3px rgba(180,83,9,0.12);}
.debt-form input:focus,.debt-form select:focus{border-color:var(–debt);box-shadow:0 0 0 3px rgba(217,119,6,0.12);}
select option{background:#fff;color:var(–text);}
.btn-submit{width:100%;padding:13px;border-radius:12px;border:none;font-family:‘Kantumruy Pro’,sans-serif;font-size:0.95rem;font-weight:700;cursor:pointer;transition:all 0.2s;}
.btn-submit.inc{background:linear-gradient(135deg,#16a34a,#22c55e);color:#fff;box-shadow:0 4px 16px rgba(22,163,74,0.25);}
.btn-submit.exp{background:linear-gradient(135deg,#dc2626,#ef4444);color:#fff;box-shadow:0 4px 16px rgba(220,38,38,0.25);}
.btn-submit.dbt{background:linear-gradient(135deg,#d97706,#f59e0b);color:#fff;box-shadow:0 4px 16px rgba(217,119,6,0.25);}
.btn-submit:hover{transform:translateY(-1px);filter:brightness(1.08);}
.btn-submit:disabled{opacity:0.6;cursor:not-allowed;transform:none;}

/* Rate */
.rate-box{background:var(–khr-bg);border:1.5px solid var(–khr-border);border-radius:11px;padding:12px 15px;margin-bottom:16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.rate-box-label{font-size:0.8rem;color:var(–khr);font-weight:700;white-space:nowrap;}
.rate-box input{flex:1;min-width:100px;background:#fff;border-color:var(–khr-border);padding:7px 10px;font-size:0.88rem;}
.rate-display{font-size:0.78rem;color:var(–khr);font-weight:600;white-space:nowrap;}
.cur-toggle{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:12px;}
.cur-btn{padding:8px;border-radius:8px;border:1.5px solid var(–khr-border);background:#fff;color:var(–khr);font-family:‘Kantumruy Pro’,sans-serif;font-size:0.82rem;font-weight:600;cursor:pointer;transition:all 0.2s;text-align:center;}
.cur-btn.active{background:var(–khr);color:#fff;border-color:var(–khr);}
.debt-cur-toggle{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:12px;}
.debt-cur-btn{padding:8px;border-radius:8px;border:1.5px solid var(–debt-border);background:#fff;color:var(–debt);font-family:‘Kantumruy Pro’,sans-serif;font-size:0.82rem;font-weight:600;cursor:pointer;transition:all 0.2s;text-align:center;}
.debt-cur-btn.active{background:var(–debt);color:#fff;border-color:var(–debt);}
.convert-preview{background:var(–khr-bg);border:1px dashed var(–khr-border);border-radius:8px;padding:9px 13px;margin-bottom:12px;font-size:0.8rem;color:var(–khr);font-weight:600;display:none;}

/* FILTERS */
.filters{display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap;}
.filter-btn{padding:7px 16px;border-radius:8px;border:1.5px solid var(–border);background:var(–surface);color:var(–text2);font-family:‘Kantumruy Pro’,sans-serif;font-size:0.82rem;font-weight:500;cursor:pointer;transition:all 0.2s;}
.filter-btn:hover,.filter-btn.active{background:var(–accent);color:#fff;border-color:var(–accent);}
.filter-btn.kf:hover,.filter-btn.kf.active{background:var(–khr);border-color:var(–khr);}
.filter-btn.df:hover,.filter-btn.df.active{background:var(–debt);border-color:var(–debt);}
.search-box{flex:1;min-width:150px;padding:7px 12px;border-radius:8px;border:1.5px solid var(–border);background:var(–surface);color:var(–text);font-family:‘Kantumruy Pro’,sans-serif;font-size:0.82rem;outline:none;}
.search-box:focus{border-color:var(–accent);}
.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.section-title{font-family:‘Hanuman’,serif;font-size:1.05rem;font-weight:700;color:var(–text);}
.clear-btn{padding:5px 12px;border-radius:7px;border:1.5px solid var(–expense);background:transparent;color:var(–expense);font-family:‘Kantumruy Pro’,sans-serif;font-size:0.78rem;cursor:pointer;transition:all 0.2s;}
.clear-btn:hover{background:var(–expense-bg);}

/* TRANSACTION ITEM */
.t-list{display:flex;flex-direction:column;gap:9px;}
.t-item{background:var(–surface);border:1px solid var(–border);border-radius:13px;padding:14px 16px;display:flex;align-items:center;gap:12px;animation:slideIn 0.3s ease both;transition:transform 0.2s;position:relative;overflow:hidden;box-shadow:0 2px 8px rgba(124,106,247,0.05);}
.t-item::before{content:’’;position:absolute;left:0;top:0;bottom:0;width:3px;}
.t-item.income::before{background:var(–income);}
.t-item.expense::before{background:var(–expense);}
.t-item:hover{transform:translateX(3px);}
.t-icon{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;}
.t-icon.income{background:var(–income-bg);}
.t-icon.expense{background:var(–expense-bg);}
.t-info{flex:1;min-width:0;}
.t-desc{font-weight:600;font-size:0.9rem;color:var(–text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.t-meta{font-size:0.75rem;color:var(–text3);margin-top:2px;display:flex;gap:8px;flex-wrap:wrap;}
.t-cat{background:var(–surface2);padding:1px 7px;border-radius:4px;color:var(–text2);}
.t-amt{font-family:‘Hanuman’,serif;font-weight:700;font-size:0.98rem;flex-shrink:0;text-align:right;}
.t-amt.income{color:var(–income);}
.t-amt.expense{color:var(–expense);}
.t-amt-sub{font-size:0.7rem;color:var(–text3);font-weight:400;margin-top:1px;}
.t-del{background:none;border:none;color:var(–text3);cursor:pointer;padding:4px;border-radius:6px;font-size:0.95rem;transition:all 0.2s;flex-shrink:0;}
.t-del:hover{color:var(–expense);background:var(–expense-bg);}

/* DEBT ITEM */
.d-item{background:var(–surface);border:1px solid var(–border);border-radius:13px;padding:14px 16px;animation:slideIn 0.3s ease both;transition:transform 0.2s;position:relative;overflow:hidden;box-shadow:0 2px 8px rgba(217,119,6,0.06);}
.d-item::before{content:’’;position:absolute;left:0;top:0;bottom:0;width:3px;background:var(–debt);}
.d-item.paid{opacity:0.75;}
.d-item.paid::before{background:var(–income);}
.d-item:hover{transform:translateX(3px);}
.d-main{display:flex;align-items:center;gap:12px;}
.d-icon{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;background:var(–debt-bg);}
.d-icon.paid{background:var(–income-bg);}
.d-info{flex:1;min-width:0;}
.d-name{font-weight:700;font-size:0.9rem;color:var(–text);}
.d-meta{font-size:0.73rem;color:var(–text3);margin-top:2px;display:flex;gap:8px;flex-wrap:wrap;}
.d-badge{padding:1px 8px;border-radius:4px;font-size:0.72rem;font-weight:700;}
.d-badge.unpaid{background:var(–debt-bg);color:var(–debt);}
.d-badge.paid{background:var(–income-bg);color:var(–income);}
.d-cur-badge{padding:1px 7px;border-radius:4px;font-size:0.7rem;font-weight:600;background:var(–surface2);color:var(–text2);}
.d-right{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0;}
.d-amt{font-family:‘Hanuman’,serif;font-weight:700;font-size:1rem;color:var(–debt);}
.d-amt.paid{color:var(–income);text-decoration:line-through;}
.d-amt-sub{font-size:0.7rem;color:var(–text3);text-align:right;}
.d-actions{display:flex;gap:5px;flex-wrap:wrap;justify-content:flex-end;}
.d-pay-btn{padding:4px 10px;border-radius:7px;border:1.5px solid var(–income);background:transparent;color:var(–income);font-family:‘Kantumruy Pro’,sans-serif;font-size:0.75rem;font-weight:600;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
.d-pay-btn:hover{background:var(–income-bg);}
.d-pay-btn.un{border-color:var(–debt);color:var(–debt);}
.d-pay-btn.un:hover{background:var(–debt-bg);}
.d-del-btn{background:none;border:none;color:var(–text3);cursor:pointer;padding:4px;border-radius:6px;font-size:0.95rem;transition:all 0.2s;}
.d-del-btn:hover{color:var(–expense);background:var(–expense-bg);}
.d-progress-wrap{margin-top:10px;padding-top:10px;border-top:1px dashed var(–border);}
.d-progress-label{font-size:0.73rem;color:var(–text2);display:flex;justify-content:space-between;margin-bottom:5px;}
.d-progress-bar{height:5px;background:var(–surface3);border-radius:99px;overflow:hidden;}
.d-progress-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,#f59e0b,#22c55e);transition:width 0.5s ease;}
.partial-area{display:none;margin-top:10px;gap:7px;align-items:center;flex-wrap:wrap;}
.partial-area.open{display:flex;}
.partial-area input{flex:1;min-width:90px;padding:7px 10px;font-size:0.83rem;}
.partial-confirm{padding:7px 13px;border-radius:8px;border:none;background:linear-gradient(135deg,#d97706,#f59e0b);color:#fff;font-family:‘Kantumruy Pro’,sans-serif;font-size:0.82rem;font-weight:600;cursor:pointer;white-space:nowrap;transition:all 0.2s;}
.partial-confirm:hover{filter:brightness(1.1);}
.pay-history{margin-top:10px;padding-top:10px;border-top:1px dashed var(–border);}
.pay-history-title{font-size:0.75rem;color:var(–debt);font-weight:700;margin-bottom:7px;}
.pay-history-row{display:flex;gap:10px;align-items:center;flex-wrap:wrap;padding:6px 10px;border-radius:8px;background:var(–surface2);margin-bottom:5px;font-size:0.76rem;color:var(–text2);}
.pay-who{font-weight:700;color:var(–text);}
.pay-amt{font-family:‘Hanuman’,serif;font-weight:700;color:var(–income);}
.pay-date{color:var(–text3);margin-left:auto;}

/* Auth modal */
.auth-modal{position:fixed;inset:0;background:rgba(30,27,75,0.55);backdrop-filter:blur(6px);z-index:8000;display:flex;align-items:center;justify-content:center;padding:16px;}
.auth-box{background:#fff;border-radius:22px;padding:32px 28px;width:100%;max-width:380px;box-shadow:0 20px 60px rgba(124,106,247,0.2);animation:fadeUp 0.35s ease both;}
.auth-box h2{font-family:‘Hanuman’,serif;font-size:1.4rem;font-weight:900;color:var(–accent);margin-bottom:6px;text-align:center;}
.auth-box p{font-size:0.82rem;color:var(–text2);text-align:center;margin-bottom:22px;}
.auth-box .form-group{margin-bottom:14px;}
.auth-error{background:#fee2e2;color:#dc2626;border-radius:8px;padding:8px 12px;font-size:0.8rem;font-weight:600;margin-bottom:12px;display:none;}
.auth-error.show{display:block;}
.btn-login{width:100%;padding:13px;border-radius:12px;border:none;background:linear-gradient(135deg,#7c6af7,#a78bfa);color:#fff;font-family:‘Kantumruy Pro’,sans-serif;font-size:0.95rem;font-weight:700;cursor:pointer;transition:all 0.2s;margin-top:4px;}
.btn-login:hover{filter:brightness(1.08);transform:translateY(-1px);}
.btn-login:disabled{opacity:0.6;cursor:not-allowed;transform:none;}

/* Admin bar */
.admin-bar{display:flex;align-items:center;gap:10px;background:linear-gradient(135deg,#ede9fe,#ddd6fe);border:1.5px solid #c4b5fd;border-radius:12px;padding:10px 16px;margin-bottom:16px;flex-wrap:wrap;box-shadow:0 2px 10px rgba(124,106,247,0.15);}
.admin-bar.hidden{display:none;}
.admin-bar-info{flex:1;font-size:0.82rem;color:var(–text);}
.admin-bar-info b{color:var(–accent);font-weight:700;}
.admin-badge{background:linear-gradient(135deg,#7c6af7,#a78bfa);color:#fff;padding:3px 10px;border-radius:99px;font-size:0.72rem;font-weight:700;margin-left:6px;}
.btn-logout{padding:8px 18px;border-radius:9px;border:none;background:linear-gradient(135deg,#dc2626,#ef4444);color:#fff;font-family:‘Kantumruy Pro’,sans-serif;font-size:0.82rem;font-weight:700;cursor:pointer;transition:all 0.2s;white-space:nowrap;box-shadow:0 2px 8px rgba(220,38,38,0.25);}
.btn-logout:hover{filter:brightness(1.1);transform:translateY(-1px);}

/* Guest bar */
.guest-bar{display:flex;align-items:center;gap:10px;background:linear-gradient(135deg,#fffbeb,#fef3c7);border:1.5px solid var(–khr-border);border-radius:12px;padding:10px 16px;margin-bottom:16px;flex-wrap:wrap;}
.guest-bar span{flex:1;font-size:0.82rem;color:var(–khr);font-weight:500;}
.btn-login-prompt{padding:8px 18px;border-radius:9px;border:none;background:linear-gradient(135deg,#7c6af7,#a78bfa);color:#fff;font-family:‘Kantumruy Pro’,sans-serif;font-size:0.82rem;font-weight:700;cursor:pointer;transition:all 0.2s;white-space:nowrap;box-shadow:0 2px 8px rgba(124,106,247,0.25);}
.btn-login-prompt:hover{filter:brightness(1.1);transform:translateY(-1px);}
body.is-admin .guest-bar{display:none;}

/* Hide admin-only elements for guests */
.admin-only{display:none;}
body.is-admin .admin-only{display:unset;}
body.is-admin .form-section{display:block;}
body:not(.is-admin) .form-section{display:none;}
body.is-admin .clear-btn{display:unset;}
body:not(.is-admin) .clear-btn{display:none;}
body.is-admin .t-del{display:unset;}
body:not(.is-admin) .t-del{display:none;}
body.is-admin .d-del-btn{display:unset;}
body:not(.is-admin) .d-del-btn{display:none;}
body.is-admin .d-pay-btn{display:unset;}
body:not(.is-admin) .d-pay-btn{display:none;}
body.is-admin .partial-area{display:none;}
body:not(.is-admin) .partial-area{display:none!important;}
body.is-admin .partial-area.open{display:flex;}
.chart-bars{display:flex;align-items:flex-end;gap:6px;height:110px;margin-top:14px;}
.bar-group{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;height:100%;justify-content:flex-end;}
.bar{width:100%;border-radius:5px 5px 0 0;transition:height 0.5s ease;min-height:2px;}
.bar.income{background:linear-gradient(180deg,#3fb950,#2ea043);}
.bar.expense{background:linear-gradient(180deg,#f85149,#da3633);}
.bar-label{font-size:0.67rem;color:var(–text3);text-align:center;}

/* Rate header KHR tab */
